# liquidacion_cli — .gitignore
# Generado en Fase 0 / Tarea 0.B (2026-06-12).
# Fuente: plan_modernizacion_v2.0_2026-06-09.md §5.2 + adiciones por hallazgos en vivo.

# ─────────────────────────────────────────────────────────────
# Entornos virtuales
# ─────────────────────────────────────────────────────────────
.venv/
.venv-liq/  # [ADD S14] venv local usado en `uv pip install -e .` para validar packaging
venv/
liquidacion-env/
env/
ENV/

# ─────────────────────────────────────────────────────────────
# Empaquetado
# ─────────────────────────────────────────────────────────────
*.egg-info/
build/
dist/
*.egg

# ─────────────────────────────────────────────────────────────
# Bytecode y cachés de Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ─────────────────────────────────────────────────────────────
# Cobertura de tests
# ─────────────────────────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
coverage.xml
.nyc_output/

# ─────────────────────────────────────────────────────────────
# Salidas generadas por el motor (directorios vacíos se mantienen con .gitkeep)
# ─────────────────────────────────────────────────────────────
output/                                   # artefactos de liquidación (gitignored; .gitkeep tracked)
artifacts/                                # auditoría inmutable
logs/                                     # logs de ejecución
!output/.gitkeep                          # [FIX] mantener marcador para que el dir exista post-clone
!artifacts/.gitkeep                       # [FIX]
!logs/.gitkeep                            # [FIX]
audit/                                    # [FIX] auditoría histórica (gitignored; .gitkeep tracked)
audit/**                                  # [FIX S14] subdirs concretos (logs/, reports/, trails/) — bug: audit/ solo no matcheaba contenido
!audit/.gitkeep                           # [FIX] mantener marcador
docs/audit/                               # [FIX S14] mirror histórico de auditoría en docs/
docs/audit/**                             # [FIX S14] subdirs (logs/, reports/, trails/)

# ─────────────────────────────────────────────────────────────
# Datos de ejecución local (mencionado en .env: LIQUIDACION_DATA_PATH=./data)
# ─────────────────────────────────────────────────────────────
data/                                     # [ADD] ruta de datos, puede contener PII
*.sqlite
*.sqlite3
*.db

# ─────────────────────────────────────────────────────────────
# Artefactos históricos / outputs espurios en raíz (mover o ignorar)
# ─────────────────────────────────────────────────────────────
liquidacion*.json
liquidacion*.pdf
liquidacion*.txt
finca_rural*.json
compensacion_*.json
finca_rural_result*
liquidacion_actualizada*
liquidacion_20*.pdf

# ─────────────────────────────────────────────────────────────
# Secretos y entorno
# ─────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.backup*                              # [ADD] proteger backups de rotación de clave (issue 2026-06-12)
*.pem
*.key

# ─────────────────────────────────────────────────────────────
# Scripts espurios de un solo uso (mover a scripts/_legacy/ o eliminar)
# ─────────────────────────────────────────────────────────────
/generate_liquidacion.py
/generar_varios.py
/test_encabezado.py
/Plan de ejecución.py                     # [ADD] legacy 68KB; revisar en Tarea 0.C

# ─────────────────────────────────────────────────────────────
# Backups genéricos (cualquier .bak, .backup, ~)
# ─────────────────────────────────────────────────────────────
*.bak                                     # [ADD]
*.backup                                  # [ADD]
*.tmp                                     # [ADD]
*.swp                                     # [ADD]
*~                                        # [ADD]

# ─────────────────────────────────────────────────────────────
# Logs genéricos (directorios ya ignorados arriba; este es catch-all)
# ─────────────────────────────────────────────────────────────
*.log                                     # [ADD]

# ─────────────────────────────────────────────────────────────
# Configuración de editores
# ─────────────────────────────────────────────────────────────
.vscode/                                  # [ADD]
.idea/                                    # [ADD]
*.iml                                     # [ADD]
.DS_Store                                 # [ADD]
Thumbs.db                                 # [ADD]

# ─────────────────────────────────────────────────────────────
# Documentos legacy a revisar (pueden contener PII; mover o ignorar)
# ─────────────────────────────────────────────────────────────
/documentos_legales_rurales/              # [ADD] revisar contenido en Tarea 0.C

# ─────────────────────────────────────────────────────────────
# Sistema
