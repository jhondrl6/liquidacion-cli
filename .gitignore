# liquidacion_cli — .gitignore
# Generado en Fase 0 / Tarea 0.B (2026-06-12).
# Fuente: plan_modernizacion_v2.0_2026-06-09.md §5.2 + adiciones por hallazgos en vivo.
# S26: Comentarios inline removidos — causaban que git no procesara los patrones en WSL/Windows (R-OP-09).

# Entornos virtuales
.venv/
.venv-liq/
venv/
liquidacion-env/
env/
ENV/

# Empaquetado
*.egg-info/
build/
dist/
*.egg

# Bytecode y cachés de Python
__pycache__/
*.pyc
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Cobertura de tests
.coverage
.coverage.*
htmlcov/
coverage.xml
.nyc_output/

# Salidas generadas por el motor (directorios vacíos se mantienen con .gitignore)
# artefactos de liquidación (gitignored; .gitkeep tracked)
output/
!liquidator/output/
# auditoría inmutable
artifacts/
# logs de ejecución
logs/
!output/.gitkeep
!artifacts/.gitkeep
!logs/.gitkeep
# Nota: NO usamos `audit/` como patrón porque Git ignora todos los archivos
# bajo un dir ignorado, y los `!` no los re-incluyen. Usamos `audit/**`
# (recursivo) y luego re-incluimos con `!` los templates que sí queremos
# trackear.
audit/**
!audit/.gitkeep
!audit/validacion_v2/
!audit/validacion_v2/README.md
!audit/validacion_v2/STRATEGY.md
!audit/validacion_v2/TEMPLATE_input.json
!audit/validacion_v2/caso_1/
!audit/validacion_v2/caso_2/
!audit/validacion_v2/caso_3/
!audit/validacion_v2/caso_1/input.json
!audit/validacion_v2/caso_2/input.json
!audit/validacion_v2/caso_3/input.json
!audit/validacion_v2/caso_1/comparativa.md
!audit/validacion_v2/caso_2/comparativa.md
!audit/validacion_v2/caso_3/comparativa.md
docs/audit/
docs/audit/**

# Datos de ejecución local (mencionado en .env: LIQUIDACION_DATA_PATH=./data)
data/
*.sqlite
*.sqlite3
*.db

# Artefactos históricos / outputs espurios en raíz (mover o ignorar)
liquidacion*.json
liquidacion*.pdf
liquidacion*.txt
finca_rural*.json
compensacion_*.json
finca_rural_result*
liquidacion_actualizada*
liquidacion_20*.pdf

# Secretos y entorno (no modificar orden — los .env.* dependen de que .env se liste primero)
# Backups de rotación de clave (issue 2026-06-12)
.env
.env.local
.env.*.local
.env.backup*
*.pem
*.key

# Scripts espurios de un solo uso
/generate_liquidacion.py
/generar_varios.py
/test_encabezado.py
/Plan de ejecución.py

# Backups genéricos (cualquier .bak, .backup, ~)
*.bak
*.backup
*.tmp
*.swp
*~

# Logs genéricos (directorios ya ignorados arriba; este es catch-all)
*.log

# Configuración de editores
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db

# Documentos legacy (pueden contener PII)
/documentos_legales_rurales/

# Sistema
*.swp
*.swo
.directory
